# Lokaali-kehityksessä käytettävät oletusarvot. Jos haluat vaihtaa arvoja lokaalisti, luo .env.development.local-tiedosto
VIRKAILIJA_URL=https://virkailija.untuvaopintopolku.fi
APP_URL=https://localhost:3404
TURBOPACK=1
XSTATE_INSPECT=false # Käytetäänkö statelyai inspectoria xstate-tilakoneiden debuggaamiseen?
LOCAL_TRANSLATIONS=true # Käytetäänkö paikallisia käännöksiä lokaaliajossa (fi.json-tiedostosta)?